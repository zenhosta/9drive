generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid()) @db.Char(36)
  name           String             @db.VarChar(191)
  email          String             @unique @db.VarChar(191)
  passwordHash   String             @map("password_hash") @db.VarChar(255)
  status         String             @default("active") @db.VarChar(32)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  sessions       UserSession[]
  authHandoffs   AuthHandoff[]
  providerConfigs ProviderConfig[]
  oauthStates    OauthState[]
  connectedAccounts ConnectedAccount[]
  s3StorageConfigs S3StorageConfig[]
  files          File[]
  fileShares     FileShare[]
  filePreviewTokens FilePreviewToken[]
  folders        Folder[]
  uploadSessions UploadSession[]
  auditLogs      AuditLog[]
  workspaceInvitesSent WorkspaceInvite[] @relation("WorkspaceInvitesSent")
  uploadRoutingPolicy UploadRoutingPolicy?
  apiKeys       ApiKey[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @map("user_id") @db.Char(36)
  name       String    @db.VarChar(191)
  keyPrefix  String    @map("key_prefix") @db.VarChar(32)
  keyHash    String    @unique @map("key_hash") @db.VarChar(255)
  scopes     Json
  status     String    @default("active") @db.VarChar(32)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status, createdAt])
  @@map("api_keys")
}

model UploadRoutingPolicy {
  id                 String   @id @default(uuid()) @db.Char(36)
  userId             String   @unique @map("user_id") @db.Char(36)
  mode               String   @default("most_available") @db.VarChar(32)
  priorityAccountIds Json     @map("priority_account_ids")
  roundRobinCursor   Int      @default(0) @map("round_robin_cursor")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_routing_policies")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Char(36)
  userId           String    @map("user_id") @db.Char(36)
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?   @map("user_agent") @db.Text
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

model AuthHandoff {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_handoffs")
}

model ProviderConfig {
  id                    String             @id @default(uuid()) @db.Char(36)
  userId                String?            @map("user_id") @db.Char(36)
  provider              String             @db.VarChar(32)
  clientIdEncrypted     String             @map("client_id_encrypted") @db.Text
  clientSecretEncrypted String             @map("client_secret_encrypted") @db.Text
  redirectUri           String             @map("redirect_uri") @db.Text
  scopes                Json
  status                String             @default("active") @db.VarChar(32)
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  oauthStates           OauthState[]
  connectedAccounts     ConnectedAccount[]

  @@index([userId])
  @@index([provider])
  @@map("provider_configs")
}

model OauthState {
  id               String         @id @default(uuid()) @db.Char(36)
  userId           String?        @map("user_id") @db.Char(36)
  providerConfigId String         @map("provider_config_id") @db.Char(36)
  flow             String         @default("connect") @db.VarChar(32)
  stateHash        String         @unique @map("state_hash") @db.VarChar(255)
  expiresAt        DateTime       @map("expires_at")
  usedAt           DateTime?      @map("used_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConfig   ProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("oauth_states")
}

model ConnectedAccount {
  id                    String          @id @default(uuid()) @db.Char(36)
  userId                String          @map("user_id") @db.Char(36)
  providerConfigId      String?         @map("provider_config_id") @db.Char(36)
  provider              String          @db.VarChar(32)
  providerAccountId     String          @map("provider_account_id") @db.VarChar(191)
  email                 String          @db.VarChar(191)
  displayName           String?         @map("display_name") @db.VarChar(191)
  avatarUrl             String?         @map("avatar_url") @db.Text
  accessTokenEncrypted  String?         @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?         @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime?       @map("token_expires_at")
  scopes                Json
  status                String          @default("connected") @db.VarChar(32)
  lastError             String?         @map("last_error") @db.Text
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConfig        ProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)
  storageAccount        StorageAccount?
  files                 File[]
  folders               Folder[]
  uploadSessions        UploadSession[]
  s3StorageConfig       S3StorageConfig?

  @@unique([userId, provider, providerAccountId])
  @@index([userId])
  @@index([userId, status, createdAt])
  @@map("connected_accounts")
}

model S3StorageConfig {
  id                       String           @id @default(uuid()) @db.Char(36)
  userId                   String           @map("user_id") @db.Char(36)
  connectedAccountId       String           @unique @map("connected_account_id") @db.Char(36)
  name                     String           @db.VarChar(191)
  bucket                   String           @db.VarChar(191)
  region                   String           @db.VarChar(191)
  endpoint                 String?          @db.Text
  accessKeyIdEncrypted     String           @map("access_key_id_encrypted") @db.Text
  secretAccessKeyEncrypted String           @map("secret_access_key_encrypted") @db.Text
  forcePathStyle           Boolean          @default(false) @map("force_path_style")
  prefix                   String           @default("9drive") @db.VarChar(191)
  quotaBytes               BigInt?          @map("quota_bytes")
  status                   String           @default("active") @db.VarChar(32)
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount         ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("s3_storage_configs")
}

model StorageAccount {
  id                 String           @id @default(uuid()) @db.Char(36)
  connectedAccountId String           @unique @map("connected_account_id") @db.Char(36)
  totalBytes         BigInt?          @map("total_bytes")
  usedBytes          BigInt           @default(0) @map("used_bytes")
  availableBytes     BigInt?          @map("available_bytes")
  trashBytes         BigInt?          @map("trash_bytes")
  lastSyncedAt       DateTime?        @map("last_synced_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@map("storage_accounts")
}

model File {
  id                 String           @id @default(uuid()) @db.Char(36)
  userId             String           @map("user_id") @db.Char(36)
  connectedAccountId String           @map("connected_account_id") @db.Char(36)
  folderId           String?          @map("folder_id") @db.Char(36)
  provider           String           @db.VarChar(32)
  providerFileId     String           @map("provider_file_id") @db.VarChar(191)
  name               String           @db.VarChar(255)
  mimeType           String           @map("mime_type") @db.VarChar(191)
  sizeBytes          BigInt           @map("size_bytes")
  checksum           String?          @db.VarChar(191)
  status             String           @default("active") @db.VarChar(32)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  folder             Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares             FileShare[]
  previewTokens      FilePreviewToken[]

  @@index([userId])
  @@index([userId, status, createdAt])
  @@index([userId, status, folderId, createdAt])
  @@index([connectedAccountId])
  @@index([folderId])
  @@index([providerFileId])
  @@map("files")
}

model FileShare {
  id        String    @id @default(uuid()) @db.Char(36)
  fileId    String    @map("file_id") @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  token     String?   @unique @db.VarChar(191)
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  enabled   Boolean   @default(true)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  file      File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([userId, enabled, createdAt])
  @@index([fileId, userId, enabled, createdAt])
  @@map("file_shares")
}

model FilePreviewToken {
  id        String   @id @default(uuid()) @db.Char(36)
  fileId    String   @map("file_id") @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@map("file_preview_tokens")
}

model Folder {
  id                 String            @id @default(uuid()) @db.Char(36)
  userId             String            @map("user_id") @db.Char(36)
  parentId           String?           @map("parent_id") @db.Char(36)
  connectedAccountId String?           @map("connected_account_id") @db.Char(36)
  provider           String            @default("google_drive") @db.VarChar(32)
  providerFolderId   String?           @map("provider_folder_id") @db.VarChar(191)
  name               String            @db.VarChar(255)
  color              String            @default("text-blue-500") @db.VarChar(64)
  iconUrl            String?           @map("icon_url") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent             Folder?           @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children           Folder[]          @relation("FolderChildren")
  connectedAccount   ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  files              File[]
  uploadSessions     UploadSession[]    @relation("UploadSessionFolder")

  @@index([userId])
  @@index([userId, deletedAt, updatedAt])
  @@index([userId, deletedAt, parentId, updatedAt])
  @@index([parentId])
  @@index([connectedAccountId])
  @@map("folders")
}

model UploadSession {
  id                       String            @id @default(uuid()) @db.Char(36)
  userId                   String            @map("user_id") @db.Char(36)
  targetConnectedAccountId String?           @map("target_connected_account_id") @db.Char(36)
  folderId                 String?           @map("folder_id") @db.Char(36)
  fileName                 String            @map("file_name") @db.VarChar(255)
  mimeType                 String            @map("mime_type") @db.VarChar(191)
  sizeBytes                BigInt            @map("size_bytes")
  status                   String            @db.VarChar(32)
  googleSessionUri         String?           @map("google_session_uri") @db.Text
  errorMessage             String?           @map("error_message") @db.Text
  createdAt                DateTime          @default(now()) @map("created_at")
  completedAt              DateTime?         @map("completed_at")
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetConnectedAccount   ConnectedAccount? @relation(fields: [targetConnectedAccountId], references: [id], onDelete: SetNull)
  folder                   Folder?           @relation("UploadSessionFolder", fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@map("upload_sessions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(191)
  entityType String   @map("entity_type") @db.VarChar(191)
  entityId   String?  @map("entity_id") @db.Char(36)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model WorkspaceInvite {
  id           String    @id @default(uuid()) @db.Char(36)
  inviterId    String    @map("inviter_id") @db.Char(36)
  inviteeEmail String    @map("invitee_email") @db.VarChar(191)
  targetType   String    @default("file") @map("target_type") @db.VarChar(32)
  targetId     String    @default("") @map("target_id") @db.Char(36)
  role         String    @default("viewer") @db.VarChar(32)
  status       String    @default("pending") @db.VarChar(32)
  revokedAt    DateTime? @map("revoked_at")
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  inviter      User      @relation("WorkspaceInvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([inviterId, inviteeEmail, targetType, targetId], map: "workspace_invites_target_unique")
  @@index([inviteeEmail])
  @@index([targetType, targetId])
  @@map("workspace_invites")
}
